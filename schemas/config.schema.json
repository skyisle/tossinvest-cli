{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/JungHoonGhae/tossinvest-cli/main/schemas/config.schema.json",
  "title": "tossinvest-cli config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "schema_version": {
      "type": "integer",
      "const": 2
    },
    "trading": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "grant": {
          "type": "boolean",
          "default": false
        },
        "place": {
          "type": "boolean",
          "default": false
        },
        "sell": {
          "type": "boolean",
          "default": false
        },
        "kr": {
          "type": "boolean",
          "default": false
        },
        "fractional": {
          "type": "boolean",
          "default": false
        },
        "cancel": {
          "type": "boolean",
          "default": false
        },
        "amend": {
          "type": "boolean",
          "default": false
        },
        "allow_live_order_actions": {
          "type": "boolean",
          "default": false
        },
        "dangerous_automation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "complete_trade_auth": {
              "type": "boolean",
              "default": false
            },
            "accept_product_ack": {
              "type": "boolean",
              "default": false
            },
            "accept_fx_consent": {
              "type": "boolean",
              "default": false
            }
          },
          "required": [
            "complete_trade_auth",
            "accept_product_ack",
            "accept_fx_consent"
          ]
        }
      },
      "required": [
        "grant",
        "place",
        "cancel",
        "amend",
        "allow_live_order_actions",
        "dangerous_automation"
      ]
    }
  },
  "required": [
    "schema_version",
    "trading"
  ]
}
